# ═══════════════════════════════════════════════════════════════════
# ECOMMERCE API — Environment Configuration
# Copy this file to .env and fill in your values.
# Anything marked [OPTIONAL] can be left blank to use the free default.
# ═══════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000

# ── Database (required) ───────────────────────────────────────────────
# With docker-compose: use the connection below as-is
DATABASE_URL=postgresql://postgres:secret@localhost:5432/ecommerce

# ── Redis (required) ─────────────────────────────────────────────────
# With docker-compose: use the connection below as-is
REDIS_URL=redis://localhost:6379

# ── JWT Secrets (required) ────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret
JWT_OTP_SECRET=change-me-to-yet-another-long-random-secret
JWT_EXPIRES_IN=900           # 15 minutes (seconds)
JWT_REFRESH_EXPIRES_IN=604800  # 7 days (seconds)

# ── Rate Limiting ────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=60

# ═══════════════════════════════════════════════════════════════════
# FILE STORAGE
# STORAGE_DRIVER=local  → files saved to ./uploads/ on this server (FREE, default)
# STORAGE_DRIVER=s3     → files stored in AWS S3 (requires AWS keys below)
# ═══════════════════════════════════════════════════════════════════
STORAGE_DRIVER=local

# Local storage settings (only used when STORAGE_DRIVER=local)
LOCAL_UPLOAD_DIR=./uploads   # directory relative to project root

# AWS S3 settings [OPTIONAL — only needed when STORAGE_DRIVER=s3]
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
CDN_BASE_URL=                # [OPTIONAL] CloudFront URL, e.g. https://d1234.cloudfront.net

# ═══════════════════════════════════════════════════════════════════
# PAYMENTS
# Leave RAZORPAY keys empty to disable payment verification in development.
# ═══════════════════════════════════════════════════════════════════
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ═══════════════════════════════════════════════════════════════════
# EMAIL
# Leave SMTP settings empty to log emails to console (dev mode).
# For production use: Gmail, SMTP2Go, Mailgun, AWS SES, SendGrid etc.
# ═══════════════════════════════════════════════════════════════════
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Ecommerce Store <noreply@yourstore.com>"

# ═══════════════════════════════════════════════════════════════════
# SMS [OPTIONAL]
# Leave empty to log SMS messages to console (dev mode).
# ═══════════════════════════════════════════════════════════════════
MSG91_API_KEY=
MSG91_SENDER_ID=ECMRCE

# ═══════════════════════════════════════════════════════════════════
# GOOGLE OAUTH [OPTIONAL]
# Only needed if you enable Google Sign-In.
# ═══════════════════════════════════════════════════════════════════
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
